{
  "name": "mou-app",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3500",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:status": "tsx scripts/db-status.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:migrate:status": "tsx scripts/apply-migrations.ts --status",
    "e2e:bootstrap": "tsx scripts/create-e2e-doctor.ts",
    "e2e": "npm run e2e:bootstrap && playwright test",
    "e2e:headed": "npm run e2e:bootstrap && playwright test --headed",
    "e2e:ui": "npm run e2e:bootstrap && playwright test --ui",
    "e2e:report": "playwright show-report tests/.report"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.31.0",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
