// ============================================
// MOU - Prisma Schema for Supabase
// Hand Rehabilitation Platform
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// NIVEL 1: ADMIN (Tú/Socio)
// ============================================

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("OWNER") // OWNER, PARTNER
  createdAt DateTime @default(now())

  // El admin controla todo - no tiene FKs específicas
  insurances Insurance[]

  @@map("admins")
}

// ============================================
// NIVEL 2: MUTUA (Aseguradora/Centro)
// ============================================

model Insurance {
  id           String   @id @default(uuid())
  adminId      String?  @map("admin_id") // Optional - puede no tener admin asignado
  name         String // "Mapfre", "Sanitas", etc.
  slug         String   @unique // Para URLs: "mapfre"
  logo         String?
  contactEmail String?
  phone        String?
  address      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admin    Admin?            @relation(fields: [adminId], references: [id])
  doctors  InsuranceDoctor[]
  patients Patient[]

  @@map("insurances")
}

// ============================================
// NIVEL 3: MÉDICO
// ============================================

model Doctor {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  specialization String? // "Cirujano mano", "Fisioterapeuta", etc.
  licenseNumber  String?  @map("license_number") // Número colegiado
  phone          String?
  avatar         String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Un médico puede pertenecer a varias mutuas
  insurances InsuranceDoctor[]

  // Pacientes asignados a este médico (vía Insurance)
  patientAssignments PatientAssignment[]

  // Notas de sesiones
  sessionNotes SessionNote[]

  // Grabaciones de audio
  audioRecordings AudioRecording[]

  // Tareas para pacientes
  tasks    Task[]
  sessions Session[]

  @@map("doctors")
}

// Relación many-to-many: médico ↔ mutua
model InsuranceDoctor {
  insuranceId String   @map("insurance_id")
  doctorId    String   @map("doctor_id")
  assignedAt  DateTime @default(now())
  role        String   @default("DOCTOR") // DOCTOR, COORDINATOR

  insurance Insurance @relation(fields: [insuranceId], references: [id])
  doctor    Doctor    @relation(fields: [doctorId], references: [id])

  @@id([insuranceId, doctorId])
  @@map("insurance_doctors")
}

// ============================================
// NIVEL 4: PACIENTE
// ============================================

model Patient {
  id          String    @id @default(uuid())
  insuranceId String?   @map("insurance_id") // Optional - puede no tener mutua asignada
  name        String
  email       String? // Opcional - puede no tener email
  phone       String
  birthDate   DateTime? @map("birth_date")
  diagnosis   String? // Lesión/condición
  injuryDate  DateTime? @map("injury_date") // Fecha de lesión
  notes       String? // Notas generales
  isActive    Boolean   @default(true) @map("is_active")
  
  // Métricas actuales
  ifrm        Int       @default(0) @map("ifrm")     // Índice Funcional (0-100)
  adherence   Float     @default(0.0) @map("adherence") // Adherencia (0.0-1.0)
  painLevel   Int       @default(0) @map("pain_level") // Nivel dolor (0-10)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  insurance Insurance? @relation(fields: [insuranceId], references: [id])

  // Asignación a médicos (puede tener varios médicos)
  assignments PatientAssignment[]

  // Sesiones de rehabilitación (tracking de mano)
  sessions Session[]

  // Historial de métricas (IFRM, adherencia, etc.)
  metricsHistory  PatientMetric[]
  audioRecordings AudioRecording[]
  sessionNotes    SessionNote[]
  tasks           Task[]
  alerts          Alert[]
  consentLogs     ConsentLog[]

  @@map("patients")
}

// Relación many-to-many: paciente → médico (asignado por mutua)
model PatientAssignment {
  patientId   String   @map("patient_id")
  doctorId    String   @map("doctor_id")
  insuranceId String   @map("insurance_id") // Desde qué mutua
  assignedAt  DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes       String? // "Paciente derivado por..."

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@id([patientId, doctorId, insuranceId])
  @@map("patient_assignments")
}

// Métricas históricas del paciente
model PatientMetric {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  date      DateTime @default(now())
  ifrm      Int? // Índice Funcional Rehab Mano (0-100)
  adherence Float? // Adherencia al tratamiento (0.0-1.0)
  painLevel Int? // Nivel de dolor (0-10)
  notes     String?

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_metrics")
}

// ============================================
// SESIONES DE EJERCICIO (Tracking de Mano)
// ============================================

model Session {
  id         String        @id @default(uuid())
  patientId  String        @map("patient_id")
  exerciseId String?       @map("exercise_id") // Optional - puede no tener ejercicio asignado
  doctorId   String?       @map("doctor_id") // Médico que supervisó
  startedAt  DateTime      @default(now()) @map("started_at")
  endedAt    DateTime?     @map("ended_at")
  targetReps Int           @default(10) @map("target_reps")
  status     SessionStatus @default(IN_PROGRESS)

  // Métricas calculadas
  rom          Int? // Range of Motion total
  maxFlexion   Int?
  maxExtension Int?
  repetitions  Int?
  progress     Int? // Porcentaje completado

  patient  Patient  @relation(fields: [patientId], references: [id])
  exercise Exercise? @relation(fields: [exerciseId], references: [id])
  doctor   Doctor?  @relation(fields: [doctorId], references: [id])

  repData         RepData[]
  fingerStatus    FingerStatus[]
  audioRecordings AudioRecording[]
  sessionNotes    SessionNote[]

  @@map("sessions")
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Catálogo de ejercicios
model Exercise {
  id          String  @id // 'MP_IP_BLOCKED', 'FINGERS_NO_IP_BLOCK', etc.
  name        String
  description String?
  videoUrl    String? @map("video_url")
  targetReps  Int     @default(10) @map("target_reps")

  sessions Session[]

  @@map("exercises")
}

// Datos de cada repetición
model RepData {
  id           String @id @default(uuid())
  sessionId    String @map("session_id")
  repNumber    Int    @map("rep_number")
  maxFlexion   Int    @map("max_flexion")
  maxExtension Int    @map("max_extension")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("rep_data")
}

// Estado de dedos por sesión
model FingerStatus {
  id         String       @id @default(uuid())
  sessionId  String       @map("session_id")
  fingerName FingerName
  status     FingerHealth @default(NORMAL)

  session Session @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, fingerName])
  @@map("finger_status")
}

enum FingerName {
  PULGAR
  INDICE
  MEDIO
  ANULAR
  MENIQUE
}

enum FingerHealth {
  NORMAL
  INJURED
  AMPUTATED
}

// ============================================
// SESIÓN DE AUDIO (DEL MÉDICO)
// ============================================

model AudioRecording {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  doctorId  String  @map("doctor_id")
  sessionId String? @map("session_id") // Opcional: vinculado a sesión de ejercicio

  title      String
  duration   Int // Duración en segundos
  audioUrl   String  @map("audio_url") // URL de Supabase Storage
  transcript String? // Transcripción opcional (AI)

  createdAt DateTime @default(now())

  patient Patient  @relation(fields: [patientId], references: [id])
  doctor  Doctor   @relation(fields: [doctorId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("audio_recordings")
}

// ============================================
// NOTAS DEL MÉDICO
// ============================================

model SessionNote {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  doctorId  String  @map("doctor_id")
  sessionId String? @map("session_id")

  content   String // Markdown soportado
  isPrivate Boolean @default(true) // Si solo el médico lo ve

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient  @relation(fields: [patientId], references: [id])
  doctor  Doctor   @relation(fields: [doctorId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("session_notes")
}

// ============================================
// TAREAS DEL MÉDICO PARA PACIENTE
// ============================================

model Task {
  id        String @id @default(uuid())
  patientId String @map("patient_id")
  doctorId  String @map("doctor_id")

  title       String
  description String?
  dueDate     DateTime?  @map("due_date")
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// ALERTAS DEL SISTEMA
// ============================================

model Alert {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  type        AlertType
  title       String
  description String?
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now())
  readAt      DateTime? @map("read_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("alerts")
}

// ============================================
// CONSENTIMIENTO INFORMADO
// ============================================

model ConsentLog {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  status      ConsentStatus @default(PENDING)
  version     String
  acceptedAt  DateTime @default(now()) @map("accepted_at")
  revokedAt   DateTime? @map("revoked_at")
  ipAddress   String   @map("ip_address")
  userAgent   String?  @map("user_agent")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("consent_logs")
}

enum ConsentStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

enum AlertType {
  CRITICAL
  WARNING
  INFO
}
